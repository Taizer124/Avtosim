                    <ui:Label tabindex="-1" text="Save controller field values &#10;after play mode" parse-escape-sequences="true" display-tooltip-when-elided="true" tooltip="Save the changes to the vehicle parts used and value type fields of the controller script after play mode. Changes to the scriptable objects fields are saved automatically regardless of this toggle value." style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; align-self: center; -unity-font-definition: initial;" />
                    <ui:Toggle name="SaveChangesToggle" style="width: auto; max-width: none; opacity: 1; min-width: auto; -unity-text-align: middle-left; align-self: center; justify-content: flex-start; align-items: flex-start; flex-grow: 0; flex-wrap: wrap; flex-shrink: 0; margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 2px;" />
