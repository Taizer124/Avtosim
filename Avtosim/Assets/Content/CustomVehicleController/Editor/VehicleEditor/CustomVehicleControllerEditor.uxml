                            <uie:ObjectField label="Front Suspension SO" type="Assets.VehicleController.SuspensionSO, CustomVehicleController" name="FrontSuspensionPresetField" class="inputField" />
                            <uie:ObjectField label="Rear Suspension SO" type="Assets.VehicleController.SuspensionSO, CustomVehicleController" name="RearSuspensionPresetField" class="inputField" />
