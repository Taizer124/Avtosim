                                <ui:Slider picking-mode="Ignore" value="0.33" high-value="2" direction="Vertical" inverted="false" show-input-field="true" name="FrontSuspensionHeightSliderField" tooltip="The length of the suspension that it will try to keep from the ground (in meters)." class="suspensionField" style="height: 70px; font-size: 15px; white-space: normal; text-overflow: clip; -unity-text-align: upper-left; -unity-font-style: normal; flex-direction: row-reverse; align-self: stretch; justify-content: space-around; align-items: stretch; margin-top: 10px; width: 50px; margin-left: 0; flex-grow: 1; padding-left: 0; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
