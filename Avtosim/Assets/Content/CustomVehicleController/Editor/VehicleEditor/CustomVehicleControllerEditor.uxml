                            <uie:CurveField label="Torque Curve" name="EngineTorqueCurveField" tooltip="Engine torque graph.  X-axis - rpm. Y-axis - torque. The leftmost key is the idle rpm, and the rightmost - the max rpm." class="floatInputField inputField" style="margin-bottom: 2px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:VisualElement style="flex-grow: 1; flex-direction: row; margin-top: 5px; margin-bottom: 4px;">
                                <ui:Label tabindex="-1" text="Horsepower" parse-escape-sequences="true" display-tooltip-when-elided="true" tooltip="The approximate maximum horsepower that this engine can achieve." class="inputField" style="width: 138px; margin-left: 3px; margin-top: 0; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Label tabindex="-1" text="300" parse-escape-sequences="true" display-tooltip-when-elided="true" name="HorsepowerLabel" class="inputField" style="margin-top: 0; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            </ui:VisualElement>
                            <uie:FloatField label="Max Speed (km/h)" value="999" name="EngineMaxSpeedField" readonly="false" tooltip="The maximum speed a vehicle can reach (in km/h).  In case the car is trying to accelerate beyond this value, the opposite force would be applied. Keep the value at a reasonable amount because other components may depend on it for calculations" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyEngine" name="EngineSONameTextField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Engine Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="EngineSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="inputField saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement picking-mode="Ignore" class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/EngineEditorImage.png?fileID=2800000&amp;guid=eecdf99dcf4766f4a9977bc08a4838cb&amp;type=3#EngineEditorImage&apos;); height: 150px;" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Forced Induction Settings" name="ForcedInduction" value="false" view-data-key="FOSettingsFoldout" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); margin-bottom: 15px; font-size: 24px; color: rgb(200, 200, 200); overflow: visible; width: 100%;">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: flex-start;">
                        <ui:VisualElement name="EngineStats" class="statsBlock" style="flex-grow: 1;">
                            <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Forced Induction" parse-escape-sequences="true" display-tooltip-when-elided="true" class="SubheaderLabel" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="FIHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Forced Induction SO" type="Assets.VehicleController.ForcedInductionSO, CustomVehicleController" name="ForcedInductionSOObjectField" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:EnumField label="Type" type="Assets.VehicleController.ForcedInductionType, CustomVehicleController" name="FITypeEnum" tooltip="Forced induction provides an additional boost. The way boost is provided depends on the forced induction type. Turbocharger: isn&apos;t working until certain engine rpm. Takes time to spin to full speed. Boost depends on gas input. Supercharger: constant boost. Centrifugal: boost is directly tied to engine rpm." usage-hints="None" include-obsolete-values="false" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Max Boost Pressure (PSI)" value="999" name="FOMaxBoostField" tooltip="Torque amount which will be provided at max boost" class="floatInputField inputField" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:VisualElement name="TurboParams" style="flex-grow: 1; display: flex;">
                                <ui:VisualElement name="TurboLagHolder" tooltip="Engine rpm percent after which turbo starts working" style="flex-grow: 1; flex-direction: row; margin-left: 0; width: 100%; -unity-text-align: upper-left; align-self: flex-start; justify-content: flex-start; align-items: center; max-width: 300px; display: flex; flex-wrap: nowrap;">
                                    <ui:VisualElement style="flex-grow: 1; width: 100%; flex-direction: row; align-self: stretch;">
                                        <ui:Label tabindex="-1" text="Turbo Lag&#10;" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" class="inputField" style="flex-shrink: 1; flex-grow: 1; width: 50%; margin-left: 3px; padding-right: 0;" />
                                        <ui:Slider picking-mode="Ignore" value="42" high-value="1" show-input-field="true" name="TurboLagSlider" tooltip="Percent of engine rpm, after which the turbo starts working" class="inputField" style="justify-content: flex-start; align-self: auto; align-items: flex-start; height: 30px; flex-direction: row; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-grow: 1; flex-shrink: 1; width: 40%; margin-left: 0;" />
                                        <ui:Label tabindex="-1" text="RPM %" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="align-items: center; justify-content: space-between; align-self: center; flex-direction: column; margin-left: 0; margin-right: 0; margin-top: 0; margin-bottom: 7px; padding-left: 0; padding-right: 0; padding-top: 0; padding-bottom: 0; flex-shrink: 1; flex-grow: 1; width: 10%;" />
                                    </ui:VisualElement>
                                </ui:VisualElement>
                                <uie:FloatField label="Turbo Spool Up &#10;Time (s)" value="42,2" name="TurboSpinSpeedField" tooltip="Time in which turbo will reach full boost" class="inputField" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:FloatField label="Turbo Spool Down&#10;Time (s)" value="42,2" name="TurboSpooldownSpeed" tooltip="Time, in which turbo will stop spinning from full speed after user lets go of gas." class="inputField" />
                                <ui:Toggle label="AntiLag System" name="AntiLagSystem" tooltip="AntiLag system reduces the speed at which the turbo slows down spinning. The conditions for AntiLag to occur are: 1. The boost is at maximum and the player lets go of gas. 2. The boost is at maximum and the car shifts the gear." class="inputField" />
                                <ui:VisualElement name="AntiLagParams" style="flex-grow: 1;">
                                    <ui:Slider picking-mode="Ignore" label="AntiLag Efect Strength" value="0.1" high-value="0.99" name="AntiLagEffectSlider" tooltip="Defines how much the AntiLag System slows down the turbo spinning speed after the effect occurs. At the value of 0.9 the turbo will lose speed at the 1% of the original time" show-input-field="true" class="inputField" />
                                    <ui:Slider picking-mode="Ignore" label="AntiLag Chance" value="0.5" high-value="1" show-input-field="true" name="AntiLagChanceSlider" tooltip="When an AntiLag occurs, use this chance to send event about it. Used for visual and sound effects." class="inputField" />
                                </ui:VisualElement>
                            </ui:VisualElement>
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyForcedInduction" name="FISONameTextField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Forced Induction Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="FOSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="inputField saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement picking-mode="Ignore" class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/ForcedInductionEditorImage.png?fileID=2800000&amp;guid=35a6825a881bafb4f8b1c18d9e8d1c86&amp;type=3#ForcedInductionEditorImage&apos;); height: 150px;" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Transmission Settings" name="Transmission" value="false" focusable="false" view-data-key="TransmissionSettingsFoldout" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); align-self: flex-start; margin-bottom: 15px; font-size: 24px; color: rgb(200, 200, 200); width: 100%;">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row; min-width: auto; min-height: auto; max-width: none;">
                        <ui:VisualElement name="VisualElement" class="statsBlock" style="flex-grow: 1;">
                            <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Transmission" parse-escape-sequences="true" display-tooltip-when-elided="true" class="SubheaderLabel" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="TransmissionHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Transmission SO" name="TransmissionSOField" type="Assets.VehicleController.TransmissionSO, CustomVehicleController" allow-scene-objects="true" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Foldout text="Auto Calculate Gear Ratios" name="AutoCalculateGearsFoldout" value="true" tooltip="Automatic Gear Ratio calculator. Open it to create a gear ratios list for the selected Transmission Scriptable Object based on the provided input. Alternatively, if the calculator is opened, newly added gears will have their ratios calculated based on the first gear and gear change rate." class="inputField" style="flex-direction: column; align-items: stretch; align-self: auto; justify-content: space-between; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); overflow: visible;">
                                <ui:VisualElement name="CalculateGearsMenu" focusable="false" style="flex-grow: 1; background-color: rgb(70, 70, 68); border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-top-left-radius: 3px; border-top-right-radius: 3px; border-bottom-right-radius: 3px; border-bottom-left-radius: 3px; align-items: auto; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; display: flex; align-self: stretch; margin-left: -15px;">
                                    <ui:VisualElement style="flex-grow: 1; flex-direction: row; min-width: 0; min-height: 0; align-self: stretch;">
                                        <ui:Label tabindex="-1" text="Gear Ratio&#10;Change Rate" parse-escape-sequences="true" display-tooltip-when-elided="true" style="align-self: flex-start; justify-content: center; align-items: auto; width: 50%;" />
                                        <ui:Slider picking-mode="Ignore" value="-0.27" high-value="0" show-input-field="true" low-value="-1" name="GearRatioChangeRateSlider" inverted="false" class="inputField" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); width: 50%; flex-grow: 1; align-self: stretch; justify-content: space-around; align-items: auto; overflow: hidden; flex-shrink: 1;" />
                                    </ui:VisualElement>
                                    <uie:FloatField label="First Gear Ratio" value="3.45" name="GearRatioChangeRateSlider" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                    <uie:IntegerField label="Gear Amount" value="5" name="GearAmountField" tooltip="The amount of gears this transmission will have excluding the reverse gear." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                    <ui:Button text="Calculate Gear Ratios" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CulculateGearRatiosButton" class="inputField" style="-unity-text-align: upper-center; padding-left: 10px; margin-left: 0; margin-right: 0; padding-right: 0; align-self: center; justify-content: center; align-items: center;" />
                                </ui:VisualElement>
                            </ui:Foldout>
                            <ui:ListView focusable="true" name="GearRatiosSlidersList" show-foldout-header="true" header-title="Gear Ratios" show-add-remove-footer="true" tooltip="Gear ratios of the transmission. The reverse gear has the same ratio as the first gear. The higher the ratio the more torque the gear produces, but the top speed gets lower. Gear ratios must decrease as the gear number increases. When adding a new gear, its ratio will be approximated based on the first gear ratio and its index using the formula              Gear N Ratio = Gear 0 Ratio * e^(-0.27f * index)" class="inputField" style="font-size: 14px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); max-height: none; align-self: auto; align-items: auto; justify-content: flex-start; overflow: visible;" />
                            <ui:VisualElement picking-mode="Ignore" class="specialBackground">
                                <ui:Label tabindex="-1" text="Final Drive" parse-escape-sequences="true" display-tooltip-when-elided="true" tooltip="Additional multiplier to the current gear ratio. Increasing the final drive increases the acceleration but lowers the top speed." class="inputField" style="width: 50%; margin-left: 3px; margin-bottom: 5px; align-self: center; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-shrink: 1; flex-grow: 1;" />
                                <ui:Slider picking-mode="Ignore" value="42" high-value="10" tooltip="Additional multiplier to the current gear ratio. Increasing the final drive increases the acceleration but lowers the top speed." name="FinalDriveInput" show-input-field="true" low-value="0.1" class="inputField" style="flex-grow: 1; padding-right: 0; margin-left: 3px; padding-top: 0; padding-bottom: 0; padding-left: 8px; width: 60%; flex-direction: column; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-shrink: 1;" />
                            </ui:VisualElement>
                            <ui:VisualElement name="SliderHolder" style="flex-grow: 1; flex-direction: row; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Upshift &#10;RPM Percent" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="flex-shrink: 0; flex-grow: 0; width: 138px; margin-left: 3px;" />
                                <ui:Slider picking-mode="Ignore" value="0.92" high-value="0.99" name="UpshiftRPMSlider" show-input-field="true" tooltip="RPM percent after which the automatic transmission will upshift." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); overflow: visible; width: 100%; flex-grow: 0; flex-shrink: 1;" />
                            </ui:VisualElement>
                            <ui:VisualElement name="SliderHolder" style="flex-grow: 1; flex-direction: row; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Downshift &#10;RPM Percent" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="width: 138px; margin-left: 3px;" />
                                <ui:Slider picking-mode="Ignore" value="0.75" high-value="1" name="DownshiftRPMSlider" show-input-field="true" tooltip="RPM percent at which the automatic transmission aims to land after downshift. If the vehicle get stuck between up and downshifting, lower the value or decrease shift cooldown." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); overflow: visible; flex-shrink: 1; flex-grow: 1;" />
                            </ui:VisualElement>
                            <uie:FloatField label="Shift Cooldown (s)" value="42,2" name="ShiftCooldownInput" tooltip="The amount of time it takes to shift gears. During this time the car can&apos;t accelerate." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyTransmission" name="TransmissionAssetName" class="floatInputField inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Transmission Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CreateTransmissionAssetButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="inputField saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/TransmissionEditorImage.png?fileID=2800000&amp;guid=e3aec65fa4f85944db8ee61d4cd152e3&amp;type=3#TransmissionEditorImage&apos;); width: 500px;" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Nitrous Settings" name="Nitrous" value="false" focusable="false" view-data-key="NitrousSettingsFoldout" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); margin-bottom: 15px; font-size: 24px; color: rgb(200, 200, 200);">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row;">
                        <ui:VisualElement name="VisualElement" class="statsBlock" style="flex-grow: 1;">
                            <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Nitrous" parse-escape-sequences="true" display-tooltip-when-elided="true" class="SubheaderLabel" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="NitrousHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Nitrous SO" name="NitrousSOField" type="Assets.VehicleController.NitrousSO, CustomVehicleController" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Boost Amount" value="2000" name="NitroBoostAmount" tooltip="The capacity of the nitrous bottle. It is depleted by Boost Intensity * deltaTime value." class="inputField" />
                            <uie:IntegerField label="Bottles Amount" value="1" name="NitroBottlesAmount" tooltip="Each bottle has a capacity of Boost Amount, meaning 4 bottles of 1000 boost amount = 4000 boost amount." class="inputField" />
                            <uie:FloatField label="Boost Intensity" value="500" name="NitroBoostIntensity" tooltip="The amount of torque, provided to the engine." class="inputField" />
                            <uie:FloatField label="Boost Warm Up Time" value="42,2" name="NitrousBoostWarmup" tooltip="Boost Warm Up Time is the time required to achieve the full effect of the boost intensity." class="inputField" />
                            <ui:Toggle label="Boost During Warmup" name="BoostDuringWarmupToggle" class="inputField" />
                            <uie:FloatField label="Recharge Rate" value="300" name="NitroRechargeRate" tooltip="The amount of boost capacity restored per second." class="inputField" />
                            <uie:FloatField label="Recharge Delay (s)" value="2" name="NitroRechargeDelay" tooltip="Delay before recharhing the nitrous bottle in seconds." class="inputField" />
                            <ui:VisualElement tooltip="Minimum percent of boost left to activate boost." style="flex-grow: 1; flex-direction: row; align-self: stretch; margin-left: 3px;">
                                <ui:Label tabindex="-1" text="Min Percent To Use" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="width: 50%;" />
                                <ui:Slider picking-mode="Ignore" value="0.1" high-value="1" name="NitroMinUse" show-input-field="true" class="inputField" style="flex-shrink: 1; flex-grow: 1;" />
                            </ui:VisualElement>
                            <uie:EnumField label="Boost Type" type="Assets.VehicleController.NitroBoostType, CustomVehicleController" name="NitroBoostType" tooltip="Continuous Boost: works as long as the user is holding the boost button. OneShot: works when the user pressed the button and it will provide boost until the bottle is empty, regardless of the further input." class="inputField" />
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyNitrous" name="NitrousAssetName" class="floatInputField inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Nitrous Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CreateNitrousAssetButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="inputField saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement picking-mode="Ignore" name="Img" class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/NitrousEditorImage.png?fileID=2800000&amp;guid=db7ffd955d7ae034f9549778db79abec&amp;type=3#NitrousEditorImage&apos;); height: 200px; -unity-background-scale-mode: scale-to-fit; opacity: 1; -unity-slice-left: 0; flex-wrap: nowrap; flex-direction: column;" />
                    </ui:VisualElement>
                </ui:Foldout>
            </ui:Foldout>
            <ui:Foldout text="Handling Settings" name="HandlingFoldout" value="false" view-data-key="HandlingSettingsFoldout" class="Foldout" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); -unity-font-definition: initial; width: 100%;">
                <uie:EnumField label="Drivetrain type" type="Assets.VehicleController.DrivetrainType, CustomVehicleController" include-obsolete-values="true" name="DrivetrainTypeEnum" tooltip="Defines what wheels cause the vehicle to move." class="statsBlock" style="height: 30px; max-width: 300px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); margin-bottom: 15px; font-size: 24px; -unity-text-align: middle-left; align-self: flex-start; justify-content: flex-end; align-items: stretch; margin-top: 10px;" />
                <ui:Foldout text="Tires Settings" name="Tires" value="false" focusable="false" view-data-key="TiresSettingsFoldout" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); font-size: 24px; color: rgb(200, 200, 200); margin-bottom: 15px;">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row;">
                        <ui:VisualElement name="Wheels" class="statsBlock" style="flex-grow: 1; flex-shrink: 0;">
                            <ui:VisualElement name="FrontWheels" class="statsBlock" style="flex-grow: 1; display: flex;">
                                <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                    <ui:Label tabindex="-1" text="Front Wheels" parse-escape-sequences="true" display-tooltip-when-elided="true" class="SubheaderLabel" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                    <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="WheelHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                                </ui:VisualElement>
                                <uie:ObjectField label="Tires SO" type="Assets.VehicleController.TiresSO, CustomVehicleController" name="ForwardTiresObjectField" class="inputField objectField" style="min-width: auto; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:FloatField label="Steering &#10;Stiffness" value="15" name="ForwardTiresCorneringStiffness" tooltip="Defines the cornering ability of a car. The higher the value, the more the car wants to move in the direction it&apos;s facing. Lower values [5:15] suitable for drift, and higher values for grip" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:CurveField label="Sideways &#10;Grip Curve" name="ForwardTiresSidewaysGripCurve" tooltip="A sideways grip curve is a multiplier to the cornering stiffness according to the current car speed / max speed of the engine.  X-axis - speed percent, Y-axis - multiplier. If you want to keep the car at maximum grip all the time, set keys to [0:1], [1:1]. If you want the car to drift, but still handle well at high speeds, make the keys increase in value, like [0:0.2f], [1,1] and adjust cornering stiffness value" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:CurveField label="Sideways &#10;Slip Curve" name="ForwardTiresSidewaysSlipCurve" tooltip="The slip curve defines how much grip the tires have depending on the dot product of vehicle movement and forward vector. X-axis - dot product (slipping). Y-axis - grip multiplier. It is recommended to increase grip when the dot product is close to 1 because in this case car is moving perpendicular to its forward vector" class="floatInputField inputField" style="flex-grow: 1; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:FloatField label="Forward Grip" value="1" name="ForwardTiresForwardGripField" tooltip="Defines how much force a wheel can take before it starts slipping. It is a multiplier to the current wheel load. If acceleration force is higher than wheel load  * forward grip, the wheel starts slipping" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyTires" name="ForwardTiresAssetNameField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Button text="Create New Tires Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ForwardTiresSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="display: flex; flex-shrink: 0; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            </ui:VisualElement>
                            <ui:VisualElement name="RearWheels" class="statsBlock" style="flex-grow: 1; margin-top: 32px;">
                                <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                    <ui:Label tabindex="-1" text="Rear Wheels" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" class="SubheaderLabel" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                </ui:VisualElement>
                                <uie:ObjectField label="Tires SO" type="Assets.VehicleController.TiresSO, CustomVehicleController" name="RearTiresObjectField" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/VegurBold-rYOp.otf?fileID=12800000&amp;guid=0656c9b2ed8dff7499350d915788ca10&amp;type=3#VegurBold-rYOp&apos;);" />
                                <uie:FloatField label="Steering&#10;Stiffness" value="15" name="RearTiresCorneringStiffness" tooltip="Defines the cornering ability of a car. The higher the value, the more the car wants to move in the direction it&apos;s facing. Lower values [5:15] suitable for drift, and higher values for grip" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:CurveField label="Sideways&#10;Grip Curve" name="RearTiresSidewaysGripCurve" tooltip="A sideways grip curve is a multiplier to the cornering stiffness according to the current car speed / max speed of the engine.  X-axis - speed percent, Y-axis - multiplier. If you want to keep the car at maximum grip all the time, set keys to [0:1], [1:1]. If you want the car to drift, but still handle well at high speeds, make the keys increase in value, like [0:0.2f], [1,1] and adjust cornering stiffness value" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:CurveField label="Sideways &#10;Slip Curve" name="RearTiresSidewaysSlipCurve" tooltip="The slip curve defines how much grip the tires have depending on the dot product of vehicle movement and forward vector. X-axis - dot product (slipping). Y-axis - grip multiplier. It is recommended to increase grip when the dot product is close to 1 because in this case car is moving perpendicular to its forward vector" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <uie:FloatField label="Forward Grip" value="1" name="RearTiresForwardGripField" tooltip="Defines how much force a wheel can take before it starts slipping. It is a multiplier to the current wheel load. If acceleration force is higher than wheel load  * forward grip, the wheel starts slipping" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyTires" name="RearTiresAssetNameField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Button text="Create New Tires Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="RearTiresSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="SteeringIMg" picking-mode="Ignore" class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/VehicleSteeringEditorImage.png?fileID=2800000&amp;guid=b508a898da655c14eaa364be7873c1c9&amp;type=3#VehicleSteeringEditorImage&apos;); -unity-background-scale-mode: scale-to-fit;" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Suspension Settings" name="Suspension" value="false" view-data-key="SuspensionSettingsFoldout" class="SubFoldout" style="font-size: 24px; margin-bottom: 15px; color: rgb(200, 200, 200);">
                    <ui:VisualElement style="flex-grow: 1; width: 100%; height: 100%; flex-direction: row; padding-right: 30px;">
                        <ui:VisualElement name="FrontSuspSetup" style="flex-grow: 1; -unity-text-align: upper-left; align-items: flex-end; justify-content: flex-start; width: 250px; flex-direction: column; align-self: auto;">
                            <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row-reverse; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Front" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" class="SubheaderLabel" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="SuspHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Suspension SO" name="FrontSuspensionObjectField" type="Assets.VehicleController.SuspensionSO, CustomVehicleController" class="suspensionObjectField" style="align-self: flex-end; align-items: flex-end; width: 100%; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Suspension Stiffness" value="60000" name="FrontSuspensionStiffnessField" tooltip="Defines the amount of force that is applied to the suspension. If the value is too low, the suspension won&apos;t be able to keep the car at a desired height above the ground. Vehicle mass has an influence on the amount of force required." class="suspensionField" style="align-items: flex-start; align-self: flex-end; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Damper Stiffness" value="3500" name="FrontSuspensionDamperField" tooltip="Damper stiffness defines how much the suspension wants to travel. If the value is 0, the suspension will bounce forever." class="suspensionField" style="font-size: 15px; -unity-font-style: normal; width: 154px; flex-direction: column; align-self: flex-end; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
