                    <ui:Label tabindex="-1" text="It seems like the controller hasn&apos;t been initialized yet. Drag wheel transform references and vehicle body MeshRenderer into appropriate fields and initialize the controller." parse-escape-sequences="true" display-tooltip-when-elided="true" name="ControllerNotInitializedLabel" class="inputField specialBackground" style="color: rgb(255, 138, 0); font-size: 14px; white-space: normal; text-overflow: clip; -unity-text-align: upper-left; flex-direction: column; flex-shrink: 0; max-width: 100%; -unity-font-style: bold; display: none; flex-grow: 0; align-self: center; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                    <ui:Button text="Initialize Controller" parse-escape-sequences="true" display-tooltip-when-elided="true" name="InitializeController" tooltip="Drag and drop appropriate game objects which represent wheels into transform fields. This button will create a hierarchy of game objects, add needed scripts and populate controller scripts with appropriate references. Since hierarchy will be changed, the root game object can&apos;t be a prefab." class="saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                </ui:VisualElement>
            </ui:Foldout>
