                    <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyPreset" name="PresetSONameTextField" class="inputField" style="margin-top: 5px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                    <ui:Button text="Create New Preset Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="PresetSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="inputField saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
