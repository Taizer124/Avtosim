                            <uie:FloatField label="AntiRoll Force" value="42,2" name="RearAntiRollField" class="suspensionField" />
                            <ui:VisualElement class="suspensionField" style="flex-grow: 1;">
                                <ui:Label tabindex="-1" text="New Asset Name" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="margin-top: 32px; margin-left: 3px;" />
                                <ui:TextField picking-mode="Ignore" value="MySuspension" name="RearSuspensionNameField" class="suspensionField inputField" style="margin-top: 0; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-grow: 0; flex-shrink: 0; flex-direction: row;" />
                            </ui:VisualElement>
                            <ui:Button text="Create New Suspension Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" enable-rich-text="false" name="RearSuspensionSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="align-self: flex-start; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); width: 230px;" />
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Brakes Settings" name="Brakes" value="false" view-data-key="BrakesSettingsFoldout" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); font-size: 24px; color: rgb(200, 200, 200); margin-bottom: 15px;">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row;">
                        <ui:VisualElement name="Stats" class="statsBlock" style="flex-grow: 1;">
                            <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Brakes" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" class="SubheaderLabel" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="BrakesHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Brakes SO" name="BrakesObjectField" type="Assets.VehicleController.BrakesSO, CustomVehicleController" class="objectField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Brakes Strength" value="42,2" name="BrakesForceField" tooltip="Defines the stopping ability of a car. The car is slowed down by increasing drag. Recommended values [15:30]" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Handbrake Force" value="42,2" name="HandbrakeForceField" tooltip="Defines the amount of force that will be applied to the rear wheels. Unlike brakes, the car is slowed down by adding force in the opposite direction to movement. Recommended values [5000:15000]" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:VisualElement style="flex-grow: 1; flex-direction: row; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Handrake &#10;Traction Percent" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="width: 50%; flex-shrink: 1; flex-grow: 1; margin-left: 3px;" />
                                <ui:Slider picking-mode="Ignore" value="42" high-value="1" name="HandbrakeTraction" show-input-field="true" tooltip="The multiplier to the rear wheels grip when the handbrake is pulled." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-shrink: 1; flex-grow: 1; width: 50%;" />
                            </ui:VisualElement>
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyBrakes" name="BrakesNameField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Brakes Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="BrakesCreateButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement name="Img" class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/BrakesEditorImage.png?fileID=2800000&amp;guid=8f085fee1ebc0d64b8df6819c029b0da&amp;type=3#BrakesEditorImage&apos;); height: auto; -unity-background-scale-mode: scale-to-fit;" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Vehicle Body Settings" name="Body" value="false" view-data-key="BodySettingsFoldout" style="display: flex; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); -unity-font-definition: initial; font-size: 24px; color: rgb(200, 200, 200); margin-bottom: 15px; height: auto;">
                    <ui:VisualElement style="flex-grow: 1; width: 100%; flex-direction: row;">
                        <ui:VisualElement name="BodyStats" class="statsBlock">
                            <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row; justify-content: flex-start; align-items: center; align-self: stretch;">
                                <ui:Label tabindex="-1" text="Vehicle Body" parse-escape-sequences="true" display-tooltip-when-elided="true" name="Label" class="SubheaderLabel" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                                <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="BodyHelpButton" class="helpButton" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/HelpButtonImage.png?fileID=2800000&amp;guid=9470bc8a1ec71ae4da9f05b975763855&amp;type=3#HelpButtonImage&apos;);" />
                            </ui:VisualElement>
                            <uie:ObjectField label="Body SO" name="BodyObjectField" type="Assets.VehicleController.VehicleBodySO, CustomVehicleController" class="inputField objectField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Mass (kg)" value="1500" name="MassField" tooltip="Vehicle mass. Keep at a reasonable value to avoid unexpected behaviour." class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Forward drag" value="0.07" name="ForwardDragField" tooltip="Forward drag of a rigidbody. Works like air resistance that slows down the acceleration. Recommended values [0:0.2]" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Downforce" value="5" name="DownforceField" tooltip="Defines the amount of force applied to the vehicle in the downward direction. Helps stabilize the vehicle and prevents rolling over at turns. Recommended values[5:15]" class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Cornering &#10;Resistance &#10;Strength" value="0.25" name="CorneringResistanceField" tooltip="Cornering resistance simulates the vehicle control getting stiffer at high speeds. Also has the effect of wheels automatically recentering. Recommended values for drift [0:5]. Recommended values for grip [10:30], but it highly depends on the cornering stiffness of the tires." class="floatInputField inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:CurveField label="Cornering &#10;Resistance Curve " name="CorneringResistanceCurve" tooltip="A multiplier to the cornering resistance strength.  The X-axis is the current vehicle speed divided by the maximum speed of the engine. Y-axis - effect multiplier." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:TextField picking-mode="Ignore" label="New Asset Name" value="MyBody" name="BodyNameField" class="inputField" style="margin-top: 32px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:Button text="Create New Body Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CreateNewBodyButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                        </ui:VisualElement>
                        <ui:VisualElement picking-mode="Ignore" class="sideImage" style="background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/VehicleBodyEditorImage.png?fileID=2800000&amp;guid=9c351fdc02a4b4d40ad0719c4f6ceef2&amp;type=3#VehicleBodyEditorImage&apos;);" />
                    </ui:VisualElement>
                </ui:Foldout>
                <ui:Foldout text="Steering Settings" name="Steering" value="false" view-data-key="SteeringSettingsFoldout" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); font-size: 24px; color: rgb(200, 200, 200); margin-bottom: 15px;">
                    <ui:VisualElement style="flex-grow: 1; flex-direction: row; align-items: stretch;">
                        <ui:VisualElement class="statsBlock" style="flex-grow: 1;">
                            <uie:FloatField label="Max Steer Angle&#10;(deg)" value="42,2" name="SteerAngleInput" tooltip="Maximum steering angle in degrees" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <uie:FloatField label="Steer Speed (s)" value="42,2" name="SteerSpeedInput" tooltip="Time in which wheels will reach maximum steering angle. Since steering uses a smooth damp function, this time is approximate." class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                            <ui:FloatField label="Wheels Recenter &#10;Time(s)" value="42,2" name="WheelsRecenterTime" class="inputField" />
                        </ui:VisualElement>
                        <ui:VisualElement class="sideImage" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/SteeringEditorSettingsImage.png?fileID=2800000&amp;guid=21fa6148dc056704abb742b2bbcb138a&amp;type=3#SteeringEditorSettingsImage&apos;); height: 150px; width: 500px; margin-top: -15px;" />
                    </ui:VisualElement>
                </ui:Foldout>
            </ui:Foldout>
            <ui:Foldout text="Extras" name="VisualSettingsExtras" value="false" view-data-key="ExtrasFoldout" class="Foldout" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); -unity-font-definition: initial; width: 100%;">
                <ui:VisualElement picking-mode="Ignore" class="statsBlock" style="flex-grow: 1; align-items: flex-start;">
                    <uie:FloatField label="Forward Slip &#10;Threshold To&#10;Display Effect" value="0.1" name="ForwardSlipThresholdField" tooltip="Defines how much slipping is allowed until the car is considered to be slipping in the forward direction" class="inputField" style="align-self: flex-start; -unity-text-align: upper-left; white-space: nowrap; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                    <uie:FloatField label="Sideways Slip &#10;Threshold To&#10;Display Effect" value="0.3" name="SidewaysSlipThresholdField" tooltip="Defines how much slipping is allowed until the car is considered to be slipping in the sideways direction" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                    <ui:Toggle label="Aerial Controls" name="AerialControlsToggle" value="true" tooltip="Allows to control the vehicle in the air. By default uses gas/brake input to rotate along the x-axis and horizontal input to rotate along the z-axis" class="inputField" style="align-self: flex-start; justify-content: flex-start; align-items: center; margin-top: 10px; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                    <uie:FloatField label="Aerial Controls &#10;Sensitivity" value="7500" name="AerialControlsSensitivityField" tooltip="The amount of torque used to rotate the rigidbody" class="inputField" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;);" />
                </ui:VisualElement>
            </ui:Foldout>
        </ui:ScrollView>
    </ui:VisualElement>
    <ui:VisualElement name="UsePresetFooter" focusable="false" style="flex-grow: 0; flex-direction: column; align-self: flex-end; justify-content: flex-end; flex-shrink: 0; -unity-background-image-tint-color: rgb(0, 0, 0); background-color: rgba(0, 0, 0, 0.31); width: 100%; height: auto; max-height: none; padding-top: 0; padding-right: 5px; padding-bottom: 0; padding-left: 5px; align-items: flex-end; flex-basis: auto; position: relative; top: auto; bottom: 0; transform-origin: bottom; margin-top: 0;">
