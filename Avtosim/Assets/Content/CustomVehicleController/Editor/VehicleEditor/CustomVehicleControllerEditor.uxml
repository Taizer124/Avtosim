                            <uie:FloatField label="AntiRoll Force" value="42,2" name="FrontAntiRollField" class="suspensionField" />
                            <ui:VisualElement class="suspensionField" style="flex-grow: 1; height: auto;">
                                <ui:Label tabindex="-1" text="New Asset Name" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="margin-top: 32px; align-self: auto; flex-shrink: 1; flex-grow: 1; margin-left: -3px;" />
                                <ui:TextField picking-mode="Ignore" value="MySuspension" name="FrontSuspensionNameField" multiline="false" auto-correction="false" class="inputField suspensionField" style="margin-top: 0; align-items: flex-start; align-self: flex-end; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); flex-grow: 0; flex-shrink: 0; height: auto; flex-direction: row;" />
                            </ui:VisualElement>
                            <ui:Button text="Create New Suspension Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="FrontSuspensionSaveButton" tooltip="Create a new asset with default values and, if the vehicle controller is selected, update its field value." class="saveButton" style="-unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/Vegur-Yg1a.otf?fileID=12800000&amp;guid=6c91916d973bdd74fa85ea681d8ea7e9&amp;type=3#Vegur-Yg1a&apos;); width: 230px; align-self: flex-end;" />
                        </ui:VisualElement>
                        <ui:VisualElement name="CarSideImg" picking-mode="Ignore" style="flex-grow: 1; background-image: url(&apos;project://database/Assets/CustomVehicleController/Editor/Images/SuspensionEditorImage.png?fileID=2800000&amp;guid=fbc8bbac1d485364b84dba9cc86a1dea&amp;type=3#SuspensionEditorImage&apos;); -unity-background-scale-mode: scale-to-fit; width: 33%; height: 300px; align-self: center; justify-content: flex-end; align-items: stretch; margin-right: 10px; margin-left: 10px; margin-top: 0; rotate: 0;" />
