                    <ui:ListView focusable="false" name="EnginePartsIsProjectList" show-foldout-header="false" selection-type="None" virtualization-method="FixedHeight" fixed-item-height="25" show-bound-collection-size="true" reorder-mode="Simple" show-add-remove-footer="false" class="statsBlock" style="background-color: rgba(39, 39, 39, 0.61); font-size: 12px; color: rgb(143, 255, 123); -unity-text-align: middle-left; width: 200px; max-width: 200px; max-height: none; min-height: auto; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; -unity-text-outline-color: rgb(0, 0, 0); -unity-paragraph-spacing: 0; letter-spacing: 5px; margin-bottom: 0; -unity-font-style: bold; border-left-width: 2px; border-left-color: rgba(0, 0, 0, 0.51); border-right-color: rgba(0, 0, 0, 0.51); border-top-color: rgba(0, 0, 0, 0.51); border-bottom-color: rgba(0, 0, 0, 0.51);" />
                </ui:Foldout>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:ScrollView>
    <ui:VisualElement style="flex-grow: 1; width: 100%; height: 10px; border-bottom-width: 3px; border-top-width: 3px; border-left-color: rgb(0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgb(0, 0, 0); border-bottom-color: rgb(0, 0, 0); background-color: rgb(13, 190, 22);" />
    <ui:ScrollView scroll-deceleration-rate="0,135" elasticity="0,1" style="flex-grow: 1; min-width: auto; min-height: auto; height: 50%;">
        <ui:Foldout text="Engine Parts Container" value="true" class="Foldout" style="width: auto; max-width: none; margin-top: 10px; margin-bottom: 10px; margin-left: 10px; font-size: 20px; flex-grow: 1; flex-direction: column; height: auto; flex-shrink: 1;">
            <ui:VisualElement style="flex-grow: 1;">
                <ui:Label tabindex="-1" text="Selected Vehicle Controller:" parse-escape-sequences="true" display-tooltip-when-elided="true" style="font-size: 14px; margin-top: 5px; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;" />
                <ui:Label tabindex="-1" text="None" parse-escape-sequences="true" display-tooltip-when-elided="true" name="VehicleControllerLable" style="font-size: 16px; color: rgb(255, 0, 0); margin-top: 2px; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;" />
                <ui:VisualElement name="PartsHolder" style="flex-grow: 1;">
