                <ui:Foldout text="Engine Part &#10;Types Management" value="false" class="statsBlock Foldout" style="width: 300px; max-width: 300px; min-height: auto; margin-bottom: 10px; font-size: 20px; margin-top: 10px; flex-grow: 0; flex-shrink: 1;">
                    <ui:Label tabindex="-1" text="TYPE CREATION" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="margin-top: 10px; border-bottom-width: 0; border-bottom-color: rgba(0, 0, 0, 0.49); font-size: 18px; -unity-font-style: bold;" />
                    <ui:TextField picking-mode="Ignore" label="New Part Type Name" value="MyEnginePartType" name="NewEnginePartTypeName" class="inputField" style="margin-top: 5px;" />
                    <ui:Button text="Create New Engine Part Type" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CreateNewEnginePartTypeButton" class="saveButton" style="margin-top: 7px;" />
                    <ui:VisualElement style="flex-grow: 1; border-bottom-width: 5px; border-bottom-color: rgba(0, 0, 0, 0.56); margin-top: 10px; margin-bottom: 5px;" />
                    <ui:Label tabindex="-1" text="TYPE DELETION" parse-escape-sequences="true" display-tooltip-when-elided="true" class="inputField" style="-unity-font-style: bold; font-size: 18px;" />
                    <ui:DropdownField label="Part Type" index="-1" choices="System.Collections.Generic.List`1[System.String]" name="DeletePartTypeDropdown" class="inputField" />
                    <ui:Button text="Delete Selected Part Type" parse-escape-sequences="true" display-tooltip-when-elided="true" name="DeleteEnginePartTypeButton" class="saveButton" style="margin-top: 7px;" />
                </ui:Foldout>
                <ui:Foldout text="Engine Part Settings" value="false" class="statsBlock Foldout" style="font-size: 20px; flex-shrink: 1; flex-grow: 0; max-width: 300px; margin-top: 10px; margin-bottom: 10px; align-self: flex-start; flex-direction: column;">
                    <ui:DropdownField label="Engine Part Type" index="-1" choices="System.Collections.Generic.List`1[System.String]" name="EnginePartTypeField" class="inputField" />
                    <ui:VisualElement name="PartSettingsHolder" style="flex-grow: 1;">
                        <uie:ObjectField label="Engine Part SO" name="EnginePartField" class="inputField" />
                        <uie:IntegerField label="Torque Increase" value="0" name="TorqueIncreaseField" class="inputField" />
                        <ui:Toggle label="Non-linear boost" name="NonLinearBoostBoolField" class="inputField" />
                        <uie:CurveField label="Effect Curve" name="EffectCurveField" class="inputField" />
                        <ui:Toggle label="Change Working RPM" name="ChangeRPMField" class="inputField" />
                        <uie:IntegerField label="IdleRPMChange" value="0" name="IdleRPMChangeField" class="inputField" />
                        <uie:IntegerField label="MaxRPMChange" value="0" name="MaxRPMChange" class="inputField" />
                        <ui:TextField picking-mode="Ignore" label="New Asset Name" name="NewAssetTextField" class="inputField" style="margin-top: 15px;" />
                        <ui:Button text="Create New Asset" parse-escape-sequences="true" display-tooltip-when-elided="true" name="CreateNewAssetButton" class="saveButton" />
                    </ui:VisualElement>
                </ui:Foldout>
            </ui:VisualElement>
            <ui:VisualElement name="RightSide" style="flex-grow: 0; flex-direction: column; align-self: flex-start; align-items: auto; justify-content: flex-start; overflow: visible; flex-shrink: 100; margin-top: 0;">
                <ui:VisualElement style="flex-grow: 0; flex-shrink: 1; width: 250px; height: 150px; align-self: flex-end; -unity-text-outline-width: 0; border-left-color: rgb(92, 190, 5); border-right-color: rgb(92, 190, 5); border-top-color: rgb(92, 190, 5); border-bottom-color: rgb(92, 190, 5); border-bottom-width: 3px; border-left-width: 3px; background-color: rgba(0, 0, 0, 0.26); max-width: 250px; max-height: 150px; min-width: 0; min-height: 0; overflow: hidden; border-top-width: 3px;">
