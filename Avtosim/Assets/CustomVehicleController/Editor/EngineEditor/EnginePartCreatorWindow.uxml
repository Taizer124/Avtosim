                    <ui:Button text="Yes" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ConfirmDeleteButton" style="width: 25px; height: 15px; font-size: 10px; color: rgb(41, 188, 0); background-color: rgb(57, 57, 57); -unity-font-style: bold;" />
                    <ui:Button text="No" parse-escape-sequences="true" display-tooltip-when-elided="true" name="DenyDeleteButton" style="width: 25px; height: 15px; font-size: 10px; color: rgb(188, 101, 0); background-color: rgb(57, 57, 56); -unity-font-style: bold;" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
