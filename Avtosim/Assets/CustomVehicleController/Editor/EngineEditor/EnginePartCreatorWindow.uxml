    <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="DocsLinkButton" style="opacity: 1; position: relative; flex-direction: row; align-self: auto; justify-content: flex-start; align-items: auto; width: 172px; height: 17px; background-color: rgba(188, 188, 188, 0); border-left-color: rgba(149, 149, 149, 0); border-right-color: rgba(149, 149, 149, 0); border-top-color: rgba(149, 149, 149, 0); border-bottom-color: rgba(149, 149, 149, 0); padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 5px; margin-right: 0; margin-bottom: 0; margin-left: 0;">
        <ui:VisualElement class="helpButton" style="flex-grow: 0; align-self: center; margin-top: 0; margin-right: 5px; border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); flex-shrink: 0;" />
        <ui:Label tabindex="-1" text="Online Documentation" parse-escape-sequences="true" display-tooltip-when-elided="true" name="DocsLabel" style="align-self: auto; -unity-text-align: middle-left; -unity-font: url(&apos;project://database/Assets/CustomVehicleController/Editor/Font/VegurBold-rYOp.otf?fileID=12800000&amp;guid=0656c9b2ed8dff7499350d915788ca10&amp;type=3#VegurBold-rYOp&apos;); font-size: 12px; justify-content: flex-start; align-items: auto; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; width: 141px; -unity-font-style: normal; text-shadow: 0 0 0 rgba(0, 0, 0, 0); border-bottom-width: 1px; border-bottom-color: rgb(0, 114, 202); color: rgb(0, 165, 255);" />
    </ui:Button>
    <ui:ScrollView scroll-deceleration-rate="0,135" elasticity="0,1" style="flex-grow: 1; flex-direction: column; justify-content: flex-start; align-self: stretch; align-items: auto; height: 50%; min-width: auto; min-height: auto;">
        <ui:VisualElement style="flex-grow: 1; flex-direction: row; align-self: stretch; justify-content: flex-start; align-items: auto;">
