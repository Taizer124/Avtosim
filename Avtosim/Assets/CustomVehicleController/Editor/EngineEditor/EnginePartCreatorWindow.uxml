                    <ui:ListView focusable="true" name="EnginePartsContainerListView" show-add-remove-footer="true" fixed-item-height="30" show-border="false" reorderable="true" style="margin-right: 3%; max-height: none; min-height: auto; flex-grow: 1;" />
